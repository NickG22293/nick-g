# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Google Service Account ────────────────────────────────────────────────────
# Paste the entire contents of your service account JSON key file as a single
# line string value below. Steps to obtain it:
#
#  1. Go to console.cloud.google.com → IAM & Admin → Service Accounts
#  2. Create a new service account (e.g. "personal-site-docs-reader")
#  3. Under Keys → Add Key → Create new key → JSON → Download
#  4. Enable the "Google Docs API" in APIs & Services → Library
#  5. Compact the JSON to one line:
#       jq -c . < your-key-file.json
#  6. Paste the result as the value below (wrap in single quotes if using shell)
#  7. For each Google Doc you want to display:
#       Share the doc with your service account's email address (view-only)
#
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Port the API server listens on (optional, defaults to 3001)
# API_PORT=3001
